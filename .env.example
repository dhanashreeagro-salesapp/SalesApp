# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Server-Side Configurations (Node / Backend Router)
SUPABASE_URL="https://etwfpozmqsihiabexrsl.supabase.co/rest/v1/"
SUPABASE_ANON_KEY="sb_publishable_NOmO2HMhWlCjys8Q01syqw_DOaJUHdW"
SUPABASE_SERVICE_ROLE_KEY="your-service role-key"

# Supabase Client-Side Configurations (Vite Bundles / SPA)
# Note: Ensure these are configured in Vercel to allow client-side client connections.
VITE_SUPABASE_URL="https://etwfpozmqsihiabexrsl.supabase.co/rest/v1/"
VITE_SUPABASE_ANON_KEY="sb_publishable_NOmO2HMhWlCjys8Q01syqw_DOaJUHdW"

# Client API Base URL
# Prefix with VITE_ to expose to client-side. Set this if your frontend is hosted separately from the backend (e.g. on Vercel).
VITE_API_URL=
